// 개발 전용 설정 파일 — 운영 배포 전 반드시 검토
// password 값은 docker-compose.dev.yml 과 쌍으로 동작하는 개발용 자격증명
// 운영 환경에서는 환경변수 또는 별도 시크릿 관리 도구로 대체할 것
{
  "server": {
    "host": "0.0.0.0",
    "port": 12345,
    "backlog": 128,
    "max_connections": 1000,
    "tcp_no_delay": true,
    "tick_rate": 60
  },
  "logging": {
    // 운영 환경에서는 "info" 또는 "warn" 으로 변경
    "level": "debug",
    "file": false,
    "file_path": "logs/server.log"
  },
  "threading": {
    "io_threads": 1,
    "map_threads_enabled": true
  },
  "game": {
    "use_ecs": true,
    "memory_pool_size": 1000
  },
  "databases": {
    "game": {
      "enabled":   true,
      "host":      "127.0.0.1",
      "port":      13306,         // dev 포트: docker-compose.dev.yml 참고
      "name":      "lemondory_game",
      "user":      "game_user",
      "password":  "devpassword", // 운영 환경에서 반드시 변경
      "pool_size": 4
    },
    "guild": {
      "enabled":   false,
      "host":      "127.0.0.1",
      "port":      13306,
      "name":      "lemondory_game",
      "user":      "game_user",
      "password":  "devpassword", // 운영 환경에서 반드시 변경
      "pool_size": 2
    },
    "common": {
      "enabled":   false,
      "host":      "127.0.0.1",
      "port":      13306,
      "name":      "lemondory_common",
      "user":      "game_user",
      "password":  "devpassword", // 운영 환경에서 반드시 변경
      "pool_size": 2
    }
  },
  "redis": {
    "enabled":  false,
    "host":     "127.0.0.1",
    "port":     16379,            // dev 포트: docker-compose.dev.yml 참고
    "password": "",
    "db_index": 0
  },
  "maps": [
    { "id": 1, "name": "Forest",  "width": 1000.0, "height": 1000.0, "max_players": 100 },
    { "id": 2, "name": "Dungeon", "width": 800.0,  "height": 800.0,  "max_players": 50  },
    { "id": 3, "name": "City",    "width": 1500.0, "height": 1500.0, "max_players": 200 }
  ]
}
