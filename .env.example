# 복사 후 값 변경: cp .env.example .env
# .env 는 .gitignore 에 포함되어 있음 — 절대 커밋하지 말 것

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=game_user
MYSQL_PASSWORD=change_me_game

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis

# ── Game Server (prod) ───────────────────────────────────────────
GAME_PORT=12345
